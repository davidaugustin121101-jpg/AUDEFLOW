# -------------------------------------------------------
# Audeflow AI – Faktury
# Copy to .env.local and fill in your values
# -------------------------------------------------------

# Supabase (https://supabase.com/dashboard/project/<id>/settings/api)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# App URL (used for OAuth callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google / Gmail OAuth 2.0
# Create at: https://console.cloud.google.com/apis/credentials
# Scopes: gmail.readonly, userinfo.email
# Redirect URI: <APP_URL>/api/gmail/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# Microsoft / Outlook OAuth 2.0
# Create at: https://portal.azure.com
# Scopes: openid email Mail.Read offline_access
# Redirect URI: <APP_URL>/api/outlook/callback
MICROSOFT_CLIENT_ID=your_microsoft_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret
MICROSOFT_REDIRECT_URI=http://localhost:3000/api/outlook/callback

# Vercel Cron (openssl rand -hex 32)
CRON_SECRET=your_cron_secret_here
